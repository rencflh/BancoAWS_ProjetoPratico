  <transform>
    <type>ScriptValueMod</type>
    <name>JavaScript</name>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>//Script here
// Garantir que os matriculados seja um numero valido
var matriculados_int = parseInt(matriculados);
if (isNaN(matriculados_int) || matriculados_int == null) {
    matriculados_int = 0;
}

// Gerar uma nota aleatoria entre 0 e 10 (com 2 casas decimais)
var media_notas = Math.round((Math.random() * 10) * 100) / 100;

// Gerar o numero de aprovados (entre 0 e o total de matriculados)
var num_aprovados = Math.floor(Math.random() * (matriculados_int + 1));

// O resto da turma reprovou
var num_reprovados = matriculados_int - num_aprovados;

</jsScript_script>
      </jsScript>
    </jsScripts>
